# Database (choose one: DATABASE_URL or individual params)
DATABASE_URL=postgres://user:password@localhost:5432/sosagro
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sos-agro
DB_USER=sos_user
DB_PASSWORD=change-me-in-production
DB_SSL=false

# Node environment
NODE_ENV=development
PORT=3000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://app.sosagro.co

# JWT Authentication
JWT_SECRET=dev-only-change-in-production-please
JWT_EXPIRES_IN=12h

# Throttling
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Logging
LOG_LEVEL=info

# Monitoring
SENTRY_DSN=

# Admin seed
ADMIN_EMAIL=admin@sosagro.co
ADMIN_PASSWORD=change-me-in-production

# Cloudflare R2 (object storage para archivos multimedia)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=sosagro-media
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
R2_PRESIGNED_URL_EXPIRES_SECONDS=300
